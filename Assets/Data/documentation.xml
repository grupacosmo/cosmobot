<?xml version="1.0" encoding="UTF-8"?>
<documentation>
    <functions>
        <function name="findItem">
            <args>
                <arg>
                    <name>type</name>
                    <type>string</type>
                    <description>type of an item to search for, eg. 'coal'</description>
                </arg>
            </args>
            <returns>
                <type>Item|null</type>
                <description>Matching item near a robot or null if no item was found within range.</description>
            </returns>
            <description>Searches for an {{@types/Item}} object of specified type near the robot.</description>
            <example>
                const item = findItem('coal');
                if (item) {
                    log('Item found at: ' + item.getPosition());
                } else {
                    log('No item of specified type found nearby.')
                }
            </example>
            <seeAlso>
                <typeRef name="Item"/>
                <funcRef name="findClosestItem"/>
                <funcRef name="findAllItems"/>
                <funcRef name="log"/>
            </seeAlso>
        </function>
        <function name="findClosestItem">
            <args>
                <arg>
                    <name>type</name>
                    <type>string</type>
                    <description>type of an item to search for, eg. 'coal'</description>
                </arg>
            </args>
            <returns>
                <type>Item|null</type>
                <description>Matching item near a robot or null if no item was found within range.</description>
            </returns>
            <description>
                Searches for an {{@types/Item}} object of specified type near the robot. 
                If more than one are found the closest one will be retrieved.
            </description>
            <example>
                const item = findClosestItem('coal');
                if (item) {
                    log('Item found at: ' + item.getPosition());
                } else {
                    log('No item of specified type found nearby.')
                }
            </example>
            <seeAlso>
                <typeRef name="Item"/>
                <funcRef name="findItem"/>
                <funcRef name="findAllItems"/>
                <funcRef name="log"/>
            </seeAlso>
        </function>
        <function name="findAllItems">
            <args>
                <arg>
                    <name>type</name>
                    <type>string</type>
                    <description>type of an item to search for, eg. 'coal'</description>
                </arg>
            </args>
            <returns>
                <type>Array(Item)|null</type>
                <description>Matching item near a robot or null if no item was found within range.</description>
            </returns>
            <description>Searches for all {{@types/Item}} objects of specified type near the robot.</description>
            <example>
                const items = findAllItems('coal');
                for (let index = 0; index &lt; items.length; index++) {
                    const item = index[i]
                    log('Found: ' + item + ' at: ' + item.getPosition());
                }
            </example>
            <seeAlso>
                <typeRef name="Item"/>
                <funcRef name="findItem"/>
                <funcRef name="findClosestItem"/>
                <funcRef name="log"/>
            </seeAlso>
        </function>
        <function name="pickupItem">
            <args>
                <arg>
                    <name>item</name>
                    <type>Item</type>
                    <description>Item object that will be picked up.</description>
                </arg>
            </args>
            <returns>
                <type>null</type>
                <description></description>
            </returns>
            <description>
                Picks up the specified {{@types/Item}} and adds it to the robot's inventory. 
                Fails if the Item is too far.
            </description>
            <example>
                pickupItem('coal');
            </example>
            <seeAlso>
                <typeRef name="Items"/>
            </seeAlso>
        </function>
        <function name="dropItem">
            <args>
                <arg>
                    <name>itemId</name>
                    <type>string|null</type>
                    <description>ID of the item to be removed. Can be null.</description>
                </arg>
            </args>
            <returns>
                <type>null</type>
                <description></description>
            </returns>
            <description>
                Drop the specified {{@types/Item}} and removes it from the robot's inventory.
                When no itemId is provided the most recently added item will be dropped.
            </description>
            <example>
                dropItem('itemId'); // drops a specific item.
                dropItem(); // drop the most recently added item.
            </example>
            <seeAlso>
                <typeRef name="Item"/>
                <funcRef name="pickupItem"/>
            </seeAlso>
        </function>
        <function name="wait">
            <args>
